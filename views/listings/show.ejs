<% layout("./layouts/boilerplate") -%>

<link
  rel="stylesheet"
  href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
/>

<style>
  #map {
    height: 400px;
    width: 100%;
    border-radius: 1rem;
    margin-top: 1rem;
  }

  .map-section {
    margin-top: 1rem;
  }
</style>

<div class="row">
  <div class="col-lg-8 col-md-10 col-12 mx-auto mt-3">
    <h3><%= listing.title %></h3>
  </div>

  <div class="card col-lg-6 col-md-10 col-12 mx-auto show-card listing-card">
    <img
      src="<%= listing.image && listing.image.url ? listing.image.url : '' %>"
      class="card-img-top show-img"
      alt="listing_image"
    >

    <div class="card-body">
      <p class="card-text">
        Owned By :
        <i><%= listing.owner && listing.owner.username ? listing.owner.username : "Unknown User" %></i>
      </p>

      <div class="card-text mb-1">
        <% if (listing.categories && listing.categories.length > 0) { %>
          <% listing.categories.forEach(category => { %>
            <span class="badge text-bg-light me-1 mb-1"><%= category %></span>
          <% }) %>
        <% } %>
      </div>

      <p class="card-text"><%= listing.description %></p>
      <p class="card-text">&#8377; <%= listing.price ? listing.price.toLocaleString("en-IN") : 0 %></p>
      <p class="card-text"><%= listing.location %></p>
      <p class="card-text"><%= listing.country %></p>
    </div>
  </div>
</div>

<% if (currUser && listing.owner && listing.owner._id && listing.owner._id.equals(currUser._id)) { %>
  <div class="btns justify-content-center gap-2 flex-wrap">
    <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark edit-btn mb-3">Edit</a>
    <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
      <button class="btn btn-dark mb-3">Delete</button>
    </form>
  </div>
<% } %>

<div class="row map-section">
  <div class="col-lg-6 col-md-10 col-12 mx-auto">
    <hr>
    <h4>Where you'll be</h4>
    <p class="text-muted"><%= listing.location %>, <%= listing.country %></p>
    <div id="map"></div>
  </div>
</div>

<div class="row">
  <div class="col-lg-6 col-md-10 col-12 mx-auto mb-3">
    <% if (currUser) { %>
      <hr>
      <h4>Leave a Review</h4>

      <form action="/listings/<%= listing._id %>/reviews" method="POST" novalidate class="needs-validation">
        <div class="mb-3 mt-3">
          <label for="rating" class="form-label">Rating</label>
          <fieldset class="starability-slot">
            <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
            <input type="radio" id="first-rate1" name="review[rating]" value="1" />
            <label for="first-rate1" title="Terrible">1 star</label>
            <input type="radio" id="first-rate2" name="review[rating]" value="2" />
            <label for="first-rate2" title="Not good">2 stars</label>
            <input type="radio" id="first-rate3" name="review[rating]" value="3" />
            <label for="first-rate3" title="Average">3 stars</label>
            <input type="radio" id="first-rate4" name="review[rating]" value="4" />
            <label for="first-rate4" title="Very good">4 stars</label>
            <input type="radio" id="first-rate5" name="review[rating]" value="5" />
            <label for="first-rate5" title="Amazing">5 stars</label>
          </fieldset>
        </div>

        <div class="mb-3 mt-3">
          <label for="comment" class="form-label">Comments</label>
          <textarea name="review[comment]" id="comment" cols="30" rows="5" class="form-control" required></textarea>
          <div class="invalid-feedback">Please add some comments for review</div>
        </div>

        <button class="btn btn-outline-dark">Submit</button>
      </form>
    <% } %>

    <% if (listing.reviews && listing.reviews.length > 0) { %>
      <div class="row mt-4">
        <p><b>All Reviews</b></p>

        <% for (let review of listing.reviews) { %>
          <div class="card col-lg-5 col-md-12 col-12 ms-lg-3 mb-3">
            <div class="card-body">
              <h5 class="card-title">
                @<%= review.author && review.author.username ? review.author.username : "Unknown User" %>
              </h5>
              <p class="starability-result card-text" data-rating="<%= review.rating %>"></p>
              <p class="card-text"><%= review.comment %></p>

              <form class="mb-3" method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                <button class="btn btn-sm btn-dark">Delete</button>
              </form>
            </div>
          </div>
        <% } %>
      </div>
    <% } %>
  </div>
</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<script>
  const lat = <%= listing.geometry ? listing.geometry.lat : 0 %>;
  const lng = <%= listing.geometry ? listing.geometry.lng : 0 %>;

  if (lat !== 0 && lng !== 0) {
    const map = L.map("map").setView([lat, lng], 12);

    L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
      attribution: "&copy; OpenStreetMap contributors"
    }).addTo(map);

    L.marker([lat, lng])
      .addTo(map)
      .bindPopup("<%= listing.location %>, <%= listing.country %>")
      .openPopup();
  } else {
    document.getElementById("map").innerHTML =
      '<div style="height:100%;display:flex;align-items:center;justify-content:center;background:#f8f9fa;border-radius:1rem;"><p style="margin:0;color:#6c757d;">Location not available for this listing</p></div>';
  }
</script>