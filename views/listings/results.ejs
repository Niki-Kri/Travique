<% layout("./layouts/boilerplate") %>

<div class="d-flex justify-content-between align-items-center mt-3 mb-2">
  <button onclick="history.back()" class="btn btn-outline-dark">
    ← Go Back
  </button>
</div>

<h3 class="mt-4"><%= pageTitle %></h3>

<% if(allListings.length === 0){ %>
  <div class="alert alert-warning mt-4">
    No listings found.
  </div>
<% } %>

<div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 row-cols-1 mt-3">
  <% for(let listing of allListings){ %>
    <div class="col">
      <a href="/listings/<%= listing._id %>" class="listing-link">
        <div class="card listing-card h-100">
          <img
            src="<%= listing.image.url %>"
            class="card-img-top"
            alt="listing_image"
            style="height: 20rem"
          >
          <div class="card-img-overlay"></div>
          <div class="card-body">
            <p class="card-text">
              <b><%= listing.title %></b><br>

              <div class="mb-1">
                <% if(listing.categories && listing.categories.length > 0){ %>
                  <% listing.categories.forEach(category => { %>
                    <span class="badge text-bg-light me-1 mb-1"><%= category %></span>
                  <% }) %>
                <% } %>
              </div>

              &#8377; <%= listing.price.toLocaleString("en-IN") %> / night
            </p>
          </div>
        </div>
      </a>
    </div>
  <% } %>
</div>